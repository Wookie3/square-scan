# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Security Configuration
# Generate a strong random secret key for scraper endpoint validation
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SCRAPER_API_KEY=your_secret_scraper_api_key

# Rate Limiting Configuration
# Set to 'false' to disable rate limiting (development only)
RATE_LIMIT_ENABLED=true

# Scraper Cache Configuration
# Time-to-live for cached scraper results in seconds (default: 21600 = 6 hours)
SCRAPER_CACHE_TTL_SECONDS=21600

# Scraper Timeout Configuration
# Maximum time in milliseconds for a single scrape operation (default: 8000)
SCRAPER_TIMEOUT_MS=8000
